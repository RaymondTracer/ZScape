<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ZScape Light Theme Colors -->
    <!-- Background Colors -->
    <Color x:Key="PrimaryBackground">#FFF5F5F5</Color>
    <Color x:Key="SecondaryBackground">#FFE8E8E8</Color>
    <Color x:Key="TertiaryBackground">#FFDDDDDD</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#FF1A1A1A</Color>
    <Color x:Key="TextSecondary">#FF666666</Color>
    <Color x:Key="TextDisabled">#FF999999</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="AccentHover">#FF106EBE</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#FF107C10</Color>
    <Color x:Key="WarningColor">#FFD83B01</Color>
    <Color x:Key="ErrorColor">#FFC50F1F</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#FFCCCCCC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackground}" />
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackground}" />
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="{StaticResource TertiaryBackground}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

    <!-- Semantic row/status colors for Light theme -->
    <Color x:Key="RowEvenColor">#FFF0F0F0</Color>
    <Color x:Key="RowOddColor">#FFFAFAFA</Color>
    <Color x:Key="RowHoverColor">#FFE0E0E0</Color>
    <Color x:Key="RowSelectedColor">#FF0078D4</Color>
    <Color x:Key="RowFullColor">#20FF0000</Color>
    <Color x:Key="RowEmptyColor">#20CCCCCC</Color>
    <Color x:Key="RowPasswordedColor">#20DAA520</Color>
    <Color x:Key="LogVerboseColor">#FF999999</Color>
    <Color x:Key="LogInfoColor">#FF1A1A1A</Color>
    <Color x:Key="LogSuccessColor">#FF107C10</Color>
    <Color x:Key="LogWarningColor">#FFD83B01</Color>
    <Color x:Key="LogErrorColor">#FFC50F1F</Color>
    <Color x:Key="PasswordLockColor">#FFCCAA00</Color>
    <Color x:Key="OnlineColor">#FF32CD32</Color>
    <Color x:Key="OfflineColor">#FFFF6347</Color>

    <SolidColorBrush x:Key="RowEvenBrush" Color="{StaticResource RowEvenColor}" />
    <SolidColorBrush x:Key="RowOddBrush" Color="{StaticResource RowOddColor}" />
    <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHoverColor}" />
    <SolidColorBrush x:Key="RowSelectedBrush" Color="{StaticResource RowSelectedColor}" />
    <SolidColorBrush x:Key="RowFullBrush" Color="{StaticResource RowFullColor}" />
    <SolidColorBrush x:Key="RowEmptyBrush" Color="{StaticResource RowEmptyColor}" />
    <SolidColorBrush x:Key="RowPasswordedBrush" Color="{StaticResource RowPasswordedColor}" />
    <SolidColorBrush x:Key="LogVerboseBrush" Color="{StaticResource LogVerboseColor}" />
    <SolidColorBrush x:Key="LogInfoBrush" Color="{StaticResource LogInfoColor}" />
    <SolidColorBrush x:Key="LogSuccessBrush" Color="{StaticResource LogSuccessColor}" />
    <SolidColorBrush x:Key="LogWarningBrush" Color="{StaticResource LogWarningColor}" />
    <SolidColorBrush x:Key="LogErrorBrush" Color="{StaticResource LogErrorColor}" />
    <SolidColorBrush x:Key="PasswordLockBrush" Color="{StaticResource PasswordLockColor}" />
    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource OnlineColor}" />
    <SolidColorBrush x:Key="OfflineBrush" Color="{StaticResource OfflineColor}" />
</ResourceDictionary>
