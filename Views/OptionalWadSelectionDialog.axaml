<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZScape.Views.OptionalWadSelectionDialog"
        x:CompileBindings="False"
        Title="Server WAD Downloads"
        Width="720" Height="420"
        WindowStartupLocation="CenterOwner"
        MinWidth="560" MinHeight="320"
        ExtendClientAreaToDecorationsHint="False">

    <Grid Margin="12" RowDefinitions="Auto,*,Auto,Auto">
        <TextBlock Grid.Row="0"
                   Text="Required WADs will always be downloaded. Optional WADs can be unchecked to skip for this join."
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="2">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="90,100,*,160" Height="30">
                        <TextBlock Grid.Column="0" Text="Download" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Type" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="File" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Status" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SelectionItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Height="30">
                                    <Grid ColumnDefinitions="90,100,*,160">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  IsEnabled="{Binding CanChangeSelection}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TypeLabel}" VerticalAlignment="Center" Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding FileName}" VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DetailLabel}" VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis" Foreground="Gray"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <CheckBox Grid.Row="2" x:Name="RememberSkippedCheckBox"
                  Content="Remember unchecked optional PWAD names in Settings"
                  Margin="0,10,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="ContinueButton" Content="Continue" Width="90" Height="28" Click="ContinueButton_Click"/>
            <Button Content="Cancel" Width="90" Height="28" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>