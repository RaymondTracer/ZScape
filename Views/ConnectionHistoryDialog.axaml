<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:ZScape.Controls"
        x:Class="ZScape.Views.ConnectionHistoryDialog"
        x:CompileBindings="False"
        Title="Connection History"
        Width="750" Height="450"
        WindowStartupLocation="CenterOwner"
        MinWidth="550" MinHeight="350"
        ExtendClientAreaToDecorationsHint="False">
    
    <Grid Margin="10" RowDefinitions="30,*,35,45">
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Recently Connected Servers" 
                   FontWeight="Bold" FontSize="14"
                   VerticalAlignment="Center"/>
        
        <!-- Main content area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,120">
            <!-- Custom list with header -->
            <controls:ResizableListView x:Name="HistoryListView" Grid.Column="0" Margin="0,5,10,5" />
            
            <!-- Button stack -->
            <StackPanel Grid.Column="1" Spacing="5">
                <Button x:Name="ReconnectButton" Content="Reconnect" Width="105" Height="28"
                        Click="ReconnectButton_Click"/>
                <Button x:Name="CopyAddressButton" Content="Copy Address" Width="105" Height="28"
                        Click="CopyAddressButton_Click"/>
                <Button x:Name="RemoveButton" Content="Remove" Width="105" Height="28"
                        Click="RemoveButton_Click"/>
                <Button x:Name="ClearButton" Content="Clear All" Width="105" Height="28"
                        Click="ClearButton_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- Settings row -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,20,Auto,Auto">
            <TextBlock Grid.Column="0" Text="Max entries:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <controls:NumericSpinner Grid.Column="1" x:Name="MaxEntriesNumeric" 
                           Minimum="10" Maximum="500" Value="100"
                           Width="70"/>
            <TextBlock Grid.Column="3" Text="Track by:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Grid.Column="4" x:Name="TrackingModeComboBox" Width="130" Height="28"
                      VerticalAlignment="Center" Margin="0,2,0,0"
                      SelectionChanged="TrackingModeComboBox_SelectionChanged">
                <ComboBoxItem Content="Server Address"/>
                <ComboBoxItem Content="Server Name"/>
                <ComboBoxItem Content="Both"/>
            </ComboBox>
        </Grid>
        
        <!-- Bottom bar -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" x:Name="InfoLabel" 
                       Text="Double-click an entry to reconnect"
                       VerticalAlignment="Center" Foreground="Gray"/>
            <Button Grid.Column="1" x:Name="CloseButton" Content="Close" 
                    Width="80" Height="28"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
