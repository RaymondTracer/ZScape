<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZScape.Views.NotificationDebugWindow"
        Title="Notification Debug"
        Width="640" Height="470"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
        <Border Grid.Row="0"
                Padding="12"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource SecondaryBackgroundBrush}">
            <TextBlock Text="Debug-only tool for sending sample server alerts through NotificationService. Test alert clicks do not launch Zandronum or change saved notification settings."
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="Auto,12,300,*">
            <TextBlock Grid.Column="0" Text="Dispatch mode:" VerticalAlignment="Center" />
            <ComboBox Grid.Column="2"
                      x:Name="DispatchModeComboBox"
                      HorizontalAlignment="Left"
                      Width="300"
                      SelectionChanged="DispatchModeComboBox_SelectionChanged" />
        </Grid>

        <CheckBox Grid.Row="2"
                  x:Name="UseSelectedServerCheckBox"
                  Margin="0,10,0,0"
                  Content="Use the current real server when available"
                  IsChecked="True"
                  Checked="OptionsChanged"
                  Unchecked="OptionsChanged" />

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource SecondaryBackgroundBrush}">
            <StackPanel Spacing="8">
                <TextBlock Text="Current test context" FontWeight="Bold" />
                <TextBlock x:Name="ContextSummaryTextBlock" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4" Margin="0,12,0,0" ColumnDefinitions="*,12,*,12,*">
            <Button Grid.Column="0" x:Name="FavoriteAlertButton" Content="Send Favorite Alert" Height="34" Click="FavoriteAlertButton_Click" />
            <Button Grid.Column="2" x:Name="ManualAlertButton" Content="Send Manual Alert" Height="34" Click="ManualAlertButton_Click" />
            <Button Grid.Column="4" x:Name="MultiAlertButton" Content="Send Multi-Server Alert" Height="34" Click="MultiAlertButton_Click" />
        </Grid>

        <Border Grid.Row="5"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Spacing="8">
                <TextBlock Text="Debug feedback" FontWeight="Bold" />
                <TextBlock x:Name="LastDispatchTextBlock"
                           Text="No test notifications sent in this session."
                           Foreground="Gray"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="LastActivationTextBlock"
                           Text="No test notification actions received in this session."
                           Foreground="Gray"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="6" Margin="0,12,0,0" ColumnDefinitions="*,Auto,10,Auto">
            <Button Grid.Column="1" Content="Refresh Context" Width="110" Height="30" Click="RefreshContextButton_Click" />
            <Button Grid.Column="3" Content="Close" Width="90" Height="30" Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>