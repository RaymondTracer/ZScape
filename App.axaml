<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ZScape.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
        <!-- Themes are loaded at runtime by ThemeService -->
    </Application.Styles>
</Application>
